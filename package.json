{
  "name": "myott",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:recommendation": "node --test src/lib/recommendation/candidates/candidatePipeline.test.mjs src/lib/providers/tmdb/requestContext.test.mjs src/lib/providers/tmdb/multiSeedRecommendation.test.mjs src/lib/recommendation/adaptiveSeedAndGenre.test.mjs src/lib/recommendation/genres/genreTaxonomy.test.mjs src/lib/recommendation/presentation/recommendationPresentation.test.mjs src/lib/recommendation/filters/hardFilterContract.test.mjs src/lib/recommendation/preferences/submittedPreferenceSession.test.mjs src/lib/recommendation/content/contentIdentity.test.mjs src/lib/recommendation/requests/latestRequestGate.test.mjs src/lib/recommendation/qa/founderDiagnostics.test.mjs",
    "qa:recommendation": "node scripts/recommendation-qa.mjs",
    "qa:recommendation:live": "pnpm qa:recommendation:live:cold",
    "qa:recommendation:live:cold": "node --use-system-ca --env-file-if-exists=.env.local scripts/recommendation-live-qa.mjs --cold",
    "qa:recommendation:live:warm": "node --use-system-ca --env-file-if-exists=.env.local scripts/recommendation-live-qa.mjs --warm",
    "check": "pnpm test:recommendation && pnpm qa:recommendation && pnpm build",
    "founder:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action status",
    "founder:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action start",
    "founder:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action stop",
    "founder:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action restart",
    "founder:ensure": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action ensure",
    "founder:cleanup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action cleanup",
    "founder:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action verify",
    "founder:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action preflight",
    "founder:finalize": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action finalize",
    "founder:qa-ready": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action qa-ready",
    "founder:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action build",
    "founder:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action check",
    "founder:selftest": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/founder-preview.ps1 -Action selftest"
  },
  "dependencies": {
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
